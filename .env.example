# X (Twitter) API Credentials
# Get these from https://console.x.com > Apps > Your App > Keys and Tokens
TWITTER_CONSUMER_KEY=your_consumer_key_here
TWITTER_CONSUMER_SECRET=your_consumer_secret_here
TWITTER_BEARER_TOKEN=your_bearer_token_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret_here
TWITTER_OAUTH2_CLIENT_ID=your_oauth2_client_id_here
TWITTER_OAUTH2_CLIENT_SECRET=your_oauth2_client_secret_here

# Meta (Facebook + Instagram) API Credentials
# Get these from https://developers.facebook.com > Your App > Settings
# 1. Create a Facebook App at developers.facebook.com
# 2. Add "Facebook Login for Business" and "Instagram Graph API" products
# 3. Generate a Page Access Token with pages_manage_posts + instagram_content_publish permissions
# 4. Get your Page ID from your Facebook Page > About > Page ID
# 5. Get your IG Business Account ID from Graph API Explorer: GET /me/accounts?fields=instagram_business_account
META_PAGE_ACCESS_TOKEN=your_page_access_token_here
META_PAGE_ID=your_facebook_page_id_here
META_IG_USER_ID=your_instagram_business_account_id_here

# AI Content Generation
# Use ONE of these (checked in order: Forge > Google > OpenAI)
GOOGLE_API_KEY=your_google_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
